	<role name="postgres"/>
</sequence>

<constraint name="fk_category" type="fk-constraint" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="SET NULL" ref-table="public.categories" table="public.items">
	<columns names="category_id" ref-type="src-columns"/>
	<ref-columns names="category_id" ref-type="dst-columns"/>
</constraint>

<constraint name="fk_created_by" type="fk-constraint" comparison-type="MATCH SIMPLE"
	 upd-action="NO ACTION" del-action="SET NULL" ref-table="public.users" table="public.items">
	<columns names="created_by" ref-type="src-columns"/>
	<ref-columns names="user_id" ref-type="dst-columns"/>
</constraint>

<relationship name="rel_items_categories" type="relfk" layer="0"
