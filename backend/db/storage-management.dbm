	<role name="postgres"/>
</sequence>

<table name="items" layers="0" collapse-mode="2" max-obj-count="8" z-value="0">
	<schema name="public"/>
	<role name="postgres"/>
	<position x="620" y="100"/>
	<column name="item_id" not-null="true" sequence="public.items_item_id_seq">
		<type name="integer" length="0"/>
	</column>
	<column name="item_name" not-null="true">
		<type name="varchar" length="100"/>
	</column>
	<column name="category_id">
		<type name="integer" length="0"/>
	</column>
	<column name="quantity" default-value="0">
